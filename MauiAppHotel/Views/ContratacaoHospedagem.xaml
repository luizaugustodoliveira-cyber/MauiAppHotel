<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MauiAppHotel.Views.ContratacaoHospedagem"
             Title="ContrataçãoHospedagem"
             NavigationPage.HasNavigationBar="False"
             BackgroundColor="#19130F"
             >
    <VerticalStackLayout VerticalOptions="CenterAndExpand"
                         Padding="10"
                         >
        <Label   Text="Cálculo da Diária"
                 HorizontalOptions="Center"
                 FontSize="30"
                 FontAttributes="Bold"
                 FontFamily="CormorantBold"
                 TextColor="#F8F3ED"
                 BackgroundColor="#19130F"
                 Margin="0,0,0,15"
                 />
        
        

        <Border Padding="30"
                StrokeShape="RoundRectangle 20"
                StrokeThickness="1"
                Stroke="#6E5846"
                BackgroundColor="#2A211B"
                >

            <VerticalStackLayout Spacing="18">
                <Grid RowDefinitions="Auto,Auto"
                      ColumnDefinitions="2*,Auto,2*"
                      RowSpacing="18"
                      ColumnSpacing="20">

                    <Label Grid.Row="0"
                           Grid.Column="0"
                           Text="Adultos:"
                           FontSize="20"
                           FontFamily="CormorantRegular"
                           VerticalOptions="Center"/>

                    <Label Grid.Row="0"
                           Grid.Column="1"
                           TextColor="#E0B37A"
                           FontSize="20"
                           HorizontalOptions="Center"
                           VerticalOptions="Center"
                           Text="{Binding Value}"
                           BindingContext="{x:Reference stp_adultos}"/>
                    
                    <Stepper Grid.Row="0" Grid.Column="2"
                             x:Name="stp_adultos"
                             Minimum="0"
                             Maximum="10"
                             Increment="1" 
                             HorizontalOptions="End"/>

                    <Label Grid.Row="1"
                           Grid.Column="0"
                           Text="Crianças:"
                           FontSize="20"
                           FontFamily="CormorantRegular"
                           VerticalOptions="Center"/>

                    <Label Grid.Row="1" Grid.Column="1"
                           TextColor="#E0B37A"
                           FontSize="20"
                           HorizontalOptions="Center"
                           VerticalOptions="Center"
                           Text="{Binding Value}"
                           BindingContext="{x:Reference stp_criancas}"/>

                    <Stepper Grid.Row="1" Grid.Column="2"
                             x:Name="stp_criancas"
                             Minimum="0"
                             Maximum="10"
                             Increment="1"
                             HorizontalOptions="End"/>

                </Grid>

                <Label Text="Escolha sua suíte"
                       FontSize="20"
                       Margin="0,20,0,0"
                       FontFamily="CormorantRegular"
                       
                       />


                <Picker x:Name="pck_quarto"
                        Title="Selecione sua Acomodação"
                        FontFamily="CormorantRegular"/>

                <Border BackgroundColor="#3A2C23"
                        StrokeThickness="0"
                        Padding="20"
                        Margin="20"
                        StrokeShape="RoundRectangle 15">

                    <VerticalStackLayout>
                        
                        <Label Text="Período da Estadia"
                               FontSize="20"
                               FontFamily="CormorantRegular"
                               Margin="0,0,0,15"/>
                        
                        <HorizontalStackLayout>

                            <Grid   ColumnDefinitions="Auto,*"
                                    RowDefinitions="Auto,Auto"
                                    RowSpacing="15"
                                    ColumnSpacing="15">

                                <Label  Grid.Row="0"
                                        Grid.Column="0"
                                        Text="Check-in:"
                                        FontFamily="CormorantRegular"
                                        VerticalOptions="Center"/>

                                    <Border Grid.Row="0"
                                            Grid.Column="1"
                                            BackgroundColor="#19130F"
                                            Stroke="#8A6B52"
                                            Padding="9"
                                            HeightRequest="50"
                                            StrokeShape="RoundRectangle 10">

                                    <DatePicker x:Name="dtpck_checkin"
                                                Format="dd/MM/yyyy"
                                                TextColor="#F8F3ED"/>

                                </Border>

                                    <Label Grid.Row="1"
                                            Grid.Column="0"
                                            Text="Check-out:"
                                           FontFamily="CormorantRegular"
                                            VerticalOptions="Center"/>

                                    <Border Grid.Row="1"
                                            Grid.Column="1"
                                            BackgroundColor="#19130F"
                                            Stroke="#8A6B52"
                                            Padding="9"
                                            HeightRequest="50"
                                            StrokeShape="RoundRectangle 10">

                                    <DatePicker x:Name="dtpck_checkout"
                                                Format="dd/MM/yyyy"
                                                TextColor="#F8F3ED"/>

                                </Border>

                            </Grid>
                        </HorizontalStackLayout>


                    </VerticalStackLayout>

                </Border>

                <Button Text="Avançar"
                        HeightRequest="55"
                        CornerRadius="18"
                        FontSize="20"
                        FontFamily="CormorantRegular"
                        BackgroundColor="#D6A062"
                        TextColor="#2A1B12"               />



            </VerticalStackLayout>
        </Border>
    </VerticalStackLayout>
</ContentPage>